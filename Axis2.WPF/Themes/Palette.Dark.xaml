<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ==== AxisWindow "Fluent" skin — DARK theme (exact design tokens) ==== -->
    <Color x:Key="AccentColor">#FF3B82F6</Color>
    <Color x:Key="AccentDarkColor">#FF60A5FA</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1B1D23"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF25272E"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF2B2E36"/>
    <SolidColorBrush x:Key="InputBrush" Color="#FF2B2E36"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FF383B45"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FF484C58"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFE9EBEF"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF9AA1AD"/>

    <!-- Accent tints over dark surfaces (design color-mix approximated as solids). -->
    <SolidColorBrush x:Key="HoverBrush" Color="#FF2A2E39"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#FF2B3A52"/>
    <SolidColorBrush x:Key="TabActiveBrush" Color="#FF28354C"/>

    <!-- Semantic / fixed status colors (not theme-swapped in the design). -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF33C479"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FFD05A5A"/>
    <SolidColorBrush x:Key="OfflineBrush" Color="#FFC9713F"/>
</ResourceDictionary>
