<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#FF3B82F6</Color>
    <Color x:Key="AccentDarkColor">#FF60A5FA</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E2129"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF262A33"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF2E333D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FF3A404B"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FF4A515E"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFE6E8EC"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF9AA3B2"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#FF313742"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#FF2B3A52"/>
</ResourceDictionary>
