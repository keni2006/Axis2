<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ==== AxisWindow "Fluent" skin — LIGHT theme (exact design tokens) ==== -->
    <Color x:Key="AccentColor">#FF3B82F6</Color>
    <Color x:Key="AccentDarkColor">#FF2563EB</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFECEEF2"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF5F6F9"/>
    <SolidColorBrush x:Key="InputBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFE3E6EC"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFCDD3DC"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FF1E2430"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF69707D"/>

    <!-- Accent tints over light surfaces (design color-mix approximated as solids). -->
    <SolidColorBrush x:Key="HoverBrush" Color="#FFEFF5FE"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#FFDCE9FD"/>
    <SolidColorBrush x:Key="TabActiveBrush" Color="#FFE2ECFE"/>

    <!-- Semantic / fixed status colors (not theme-swapped in the design). -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF33C479"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FFD05A5A"/>
    <SolidColorBrush x:Key="OfflineBrush" Color="#FFC9713F"/>
</ResourceDictionary>
