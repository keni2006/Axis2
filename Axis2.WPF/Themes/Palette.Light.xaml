<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#FF3B82F6</Color>
    <Color x:Key="AccentDarkColor">#FF2563EB</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF3F4F6"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF9FAFB"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFD8DCE3"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFB9C0CC"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FF1F2430"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF6B7280"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#FFEAF2FE"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#FFDCEAFD"/>
</ResourceDictionary>
